  # AWS CLI e credenciais
  .aws/
  *.awscredentials
  aws.env
  application-aws.properties

  # Secrets em geral
  secrets.json
  secrets.yml
  credentials.json
  *.key
  *.pem

  # Arquivos de ambiente
  .env
  .env.local
  .env.*.local

  # IntelliJ IDEA
  .idea/
  *.iml
  *.iws
  out/

  # Java / Maven / Spring Boot
  target/
  *.class
  *.log
  logs/
  application-local.properties
  application-*.local.properties

  # Arquivos temporários
  *.tmp
  *.swp
  *~

  echo "src/main/resources/application.properties" >> .gitignore